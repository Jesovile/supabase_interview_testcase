# Root env for the production frontend deploy (docker-compose.yml).
# Copy to `.env` on the deploy host and fill with your Supabase Cloud values.
# These are baked into the SPA at build time; the anon key is a public client
# credential, so it is not secret. Rebuild after changing either value.
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<cloud anon key>
