# Consumed by Vite at BUILD time and inlined into the static bundle
# (both for `npm run dev` locally and for the Docker image build).
#
# Local development — copy to .env.local and fill from `npx supabase status`:
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your-anon-key-here
#
# Production (Supabase Cloud) — do NOT put these here; pass them as Docker build
# args via the root docker-compose.yml / root .env instead. They look like:
#   VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
#   VITE_SUPABASE_ANON_KEY=<cloud anon (publishable) key from the dashboard>
